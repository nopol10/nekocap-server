{
  "name": "nekocap-server",
  "version": "0.5.0",
  "description": "The NekoCap server",
  "main": "index.js",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/nopol10/nekocap-server"
  },
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "10.4.22",
    "@nestjs/core": "10.4.22",
    "@nestjs/mongoose": "10.1.0",
    "@nestjs/platform-express": "10.4.22",
    "@nestjs/schedule": "4.1.2",
    "@sentry/node": "^7.6.0",
    "@sentry/tracing": "^7.6.0",
    "ass-compiler": "^0.1.4",
    "axios": "1.16.1",
    "compression": "^1.7.4",
    "express": "5.2.1",
    "helmet": "^4.2.0",
    "lodash-es": "4.18.1",
    "lz-string": "1.5.0",
    "mongoose": "^8.9.5",
    "parse": "8.5.0",
    "parse-server": "9.9.1-alpha.1",
    "parse-server-firebase-auth": "3.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-filename": "1.6.3",
    "throttled-queue": "2.1.4"
  },
  "scripts": {
    "start": "node index.js",
    "build": "webpack --config webpack.prod.js",
    "docker:build": "cd .. && docker build --tag nekocap-server:latest -f nekocap-server/Dockerfile . && cd ./nekocap-server",
    "watch": "concurrently \"webpack -w --config webpack.dev.js\" \"npm:dash\"",
    "dash": "parse-dashboard --dev --config parse-dashboard-config.json",
    "dash:live": "parse-dashboard --dev --config parse-dashboard-config-live.json",
    "ytcc": "ts-node --project tsconfig-ytcc.json migration/ytcc-test.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=10.0"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@babel/runtime": "7.29.2",
    "@types/chrome": "^0.0.326",
    "@types/express": "4.17.25",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/lodash-es": "4.17.12",
    "@types/lz-string": "^1.3.34",
    "@types/node": "22.14.0",
    "babel-loader": "9.1.3",
    "concurrently": "^5.3.0",
    "copy-webpack-plugin": "12.0.2",
